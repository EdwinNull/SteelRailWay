        <mxCell id="32" parent="1" value="&lt;b&gt;Training Loss&lt;/b&gt;&lt;br&gt;L = L&lt;sub&gt;FDM&lt;/sub&gt; + λ&lt;sub&gt;cf&lt;/sub&gt; · L&lt;sub&gt;CF&lt;/sub&gt; + λ&lt;sub&gt;ca&lt;/sub&gt; · L&lt;sub&gt;CA&lt;/sub&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;L&lt;sub&gt;FDM&lt;/sub&gt;: feature distribution matching (μ,σ)&lt;br&gt;L&lt;sub&gt;CF&lt;/sub&gt;: crossmodal filter consistency&lt;br&gt;L&lt;sub&gt;CA&lt;/sub&gt;: crossmodal amplifier consistency&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#ca8a04;strokeWidth=2;fontColor=#854d0e;fontSize=11;align=center;verticalAlign=middle" vertex="1">
